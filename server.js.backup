    status: "online",
    claude: !!process.env.ANTHROPIC_API_KEY,
    kimi: !!process.env.KIMI_API_KEY,
    elevenlabs: !!process.env.ELEVEN_API_KEY,
  })
);

const PORT = process.env.PORT || 3001;
app.listen(PORT, () => console.log(`ðŸ§  Aladiah Brain running on :${PORT}`));